---
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import TOC from '../components/TOC.astro';

const {
  title = 'Docs',
  description = '',
  lang = 'en',
  slug = '',
  sections = [],
  toc = []
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;600;700&family=Newsreader:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header lang={lang} slug={slug} />

    <div class="page">
      <aside class="sidebar">
        <Sidebar sections={sections} lang={lang} currentSlug={slug} />
      </aside>

      <main class="content">
        <slot />
      </main>

      <aside class="toc">
        <TOC headings={toc} />
      </aside>
    </div>

    <div class="menu-overlay" data-menu-overlay aria-hidden="true">
      <div class="menu-panel" role="dialog" aria-modal="true" aria-label="Menu">
        <div class="menu-panel-header">
          <span class="menu-title">Menu</span>
          <button class="icon-button" data-menu-close aria-label="Close menu">
            ✕
          </button>
        </div>
        <Sidebar sections={sections} lang={lang} currentSlug={slug} />
      </div>
    </div>

    <script is:inline>
      const overlay = document.querySelector('[data-menu-overlay]');
      const openBtn = document.querySelector('[data-menu-open]');
      const closeBtn = document.querySelector('[data-menu-close]');

      const openMenu = () => {
        if (!overlay) return;
        overlay.classList.add('is-open');
        overlay.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      };

      const closeMenu = () => {
        if (!overlay) return;
        overlay.classList.remove('is-open');
        overlay.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      };

      openBtn?.addEventListener('click', openMenu);
      closeBtn?.addEventListener('click', closeMenu);
      overlay?.addEventListener('click', (event) => {
        if (event.target === overlay) closeMenu();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeMenu();
      });
    </script>
  </body>
</html>

<style lang="scss" is:global>
  :root {
    --bg: #f5f4f1;
    --surface: #ffffff;
    --ink: #1d1f22;
    --muted: #5f6368;
    --border: #e8e4df;
    --accent: #d81b80;
    --accent-2: #0d9cc6;
    --header-height: 50px;
    --sidebar-width: 210px;
    --toc-width: 220px;
    color-scheme: light;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    color: var(--ink);
    font-family: 'Lexend', 'Noto Sans TC', 'Noto Sans JP', sans-serif;
  }

  p {
    font-size: 1rem;
    line-height: 1rem;
    padding: 0;
    margin: 0;
  }


  a {
    font-size: 1rem;
    color: inherit;
    text-decoration: none;
  }

  .page {
    display: grid;
    grid-template-columns: var(--sidebar-width) minmax(0, 1fr) var(--toc-width);
  }

  .sidebar,
  .toc {
    position: sticky;
    top: calc(var(--header-height) + 16px);
    align-self: start;
    height: calc(100vh - var(--header-height) - 32px);
    overflow: auto;
    background-color: var(--surface);
  }

  .content {
    padding-top: 8px;
  }

  .menu-overlay {
    position: fixed;
    inset: 0;
    background: rgba(20, 20, 20, 0.6);
    display: none;
    z-index: 60;
    padding: 24px;
  }

  .menu-overlay.is-open {
    display: flex;
  }

  .menu-panel {
    width: 100%;
    background: var(--surface);
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.2);
    overflow: auto;
  }

  .menu-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 12px;
  }

  .menu-title {
    font-weight: 600;
  }

  .icon-button {
    border: none;
    background: transparent;
    font-size: 20px;
    cursor: pointer;
  }

  article {
    background: var(--surface);
    border-radius: 18px;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);

    h1,
    h2,
    h3 {
      margin: 0;
      scroll-margin-top: calc(var(--header-height) + 24px);
    }

    h2 {
      position: sticky;
      top: calc(var(--header-height) + 60px);
      background: var(--surface);
      margin: 32px 0 16px;
      border-bottom: 1px solid var(--border);
      z-index: 1;
    }

    h3 {
      margin-top: 24px;
    }

    p,
    li {
      line-height: 1.7;
      color: var(--ink);
    }

    code {
      font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, SFMono-Regular, Menlo, monospace;
      background: #f4f1ec;
      padding: 2px 6px;
      border-radius: 6px;
    }

    pre {
      background: #15181a;
      color: #f5f5f5;
      padding: 16px;
      overflow: auto;

      code {
        background: transparent;
        padding: 0;
      }
    }
  }

  .doc-title {
    font-size: 34px;
    margin: 0 0 12px;
    font-family: 'Newsreader', serif;
    position: sticky;
    top: var(--header-height);
    background: var(--surface);
    padding: 16px 0 12px;
    z-index: 2;
    border-bottom: 1px solid var(--border);
  }

  @media (max-width: 980px) {
    .page {
      grid-template-columns: 1fr;
      padding: 16px 16px 32px;
    }

    .sidebar,
    .toc {
      display: none;
    }

    article {
      padding: 20px 20px 40px;
    }
  }
</style>
