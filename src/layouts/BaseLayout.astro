---
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import TOC from '../components/TOC.astro';

const {
  title = 'Docs',
  description = '',
  lang = 'en',
  slug = '',
  sections = [],
  toc = []
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <Header lang={lang} slug={slug} />

    <div class="page">
      <aside class="sidebar">
        <Sidebar sections={sections} lang={lang} currentSlug={slug} />
      </aside>

      <main class="content">
        <slot />
      </main>

      <aside class="toc">
        <TOC headings={toc} />
      </aside>
    </div>

    <div class="menu-overlay" data-menu-overlay aria-hidden="true">
      <div class="menu-panel" role="dialog" aria-modal="true" aria-label="Menu">
        <div class="menu-panel-header">
          <button class="icon-button" data-menu-close aria-label="Close menu">
            ✕
          </button>
        </div>
        <Sidebar sections={sections} lang={lang} currentSlug={slug} />
      </div>
    </div>

    <script is:inline>
      const overlay = document.querySelector('[data-menu-overlay]');
      const openBtn = document.querySelector('[data-menu-open]');
      const closeBtn = document.querySelector('[data-menu-close]');

      const openMenu = () => {
        if (!overlay) return;
        overlay.classList.add('is-open');
        overlay.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      };

      const closeMenu = () => {
        if (!overlay) return;
        overlay.classList.remove('is-open');
        overlay.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      };

      openBtn?.addEventListener('click', openMenu);
      closeBtn?.addEventListener('click', closeMenu);
      overlay?.addEventListener('click', (event) => {
        if (event.target === overlay) closeMenu();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeMenu();
      });
    </script>
  </body>
</html>

<style lang="scss" is:global>
  :root {
    --bg: #f5f4f1;
    --surface: #ffffff;
    --ink: #1d1f22;
    --muted: #5f6368;
    --border: #e8e4df;
    --accent: #d81b80;
    --accent-2: #0d9cc6;
    --header-height: 50px;
    --sidebar-width: 210px;
    --toc-width: 220px;
    color-scheme: light;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: calc(var(--header-height) + 40px);
    min-height: 100%;
    width: 100%;
  }

  body {
    margin: 0;
    min-height: 100dvh;
    width: 100%;
    color: var(--ink);
    font-family: 'Lexend', 'Noto Sans TC', 'Noto Sans JP', sans-serif;
  }

  p {
    font-size: 1rem;
    line-height: 1rem;
    padding: 0;
    margin: 0;
  }


  a {
    font-size: 1rem;
    color: inherit;
    text-decoration: none;
  }

  .page {
    display: grid;
    grid-template-columns: var(--sidebar-width) minmax(0, 1fr) var(--toc-width);
  }

  .sidebar,
  .toc {
    position: sticky;
    top: calc(var(--header-height) + 16px);
    align-self: start;
    height: calc(100vh - var(--header-height) - 32px);
    overflow: auto;
    background-color: var(--surface);
    padding-left: 0.5rem;
  }

  .content {
    padding-top: 8px;
    min-width: 0;
  }

  .menu-overlay {
    position: fixed;
    inset: 0;
    background: rgba(20, 20, 20, 0.6);
    display: none;
    z-index: 60;
    padding: 24px;
  }

  .menu-overlay.is-open {
    display: flex;
  }

  .menu-panel {
    width: 100%;
    background: var(--surface);
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.2);
    overflow: auto;
  }

  .menu-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .icon-button {
    border: none;
    background: transparent;
    font-size: 20px;
    cursor: pointer;
  }

  article {
    background: var(--surface);
    border-radius: 18px;
    margin-bottom: 48px;
    padding-bottom: 48px;
    max-width: 100%;

    img {
      width: 250px;
    }

    h1 {
      margin: 0 0 16px;
      line-height: 1.2;
    }

    h2 {
      position: sticky;
      top: var(--header-height);
      background: var(--surface);
      margin: 40px 0 16px;
      padding-top: 8px;
      border-bottom: 1px solid var(--border);
      z-index: 1;
      // scroll-margin-top: calc(var(--header-height) + 40px);
    }

    h3 {
      position: sticky;
      z-index: 1;
      top: calc(var(--header-height) + 34px);
      margin: 28px 0 12px;
      padding-top: 6px;
      background: var(--surface);
      // scroll-margin-top: calc(var(--header-height) + 40px);
    }

    p,
    li {
      line-height: 1.7;
      color: var(--ink);
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    ul,
    ol {
      margin: 16px 0 20px;
      padding-left: 1.5rem;
    }

    li + li {
      margin-top: 8px;
    }

    blockquote {
      margin: 20px 0;
      padding: 14px 18px;
      border-left: 4px solid var(--accent-2);
      background: #eef7fa;
      color: var(--ink);
      border-radius: 0 12px 12px 0;
    }

    blockquote p {
      margin: 0;
    }

    a {
      color: var(--accent-2);
      text-decoration: underline;
      text-decoration-thickness: 1.5px;
      text-underline-offset: 0.15em;
      word-break: break-word;
    }

    strong,
    b {
      font-weight: 700;
    }

    table {
      width: 100%;
      max-width: 100%;
      margin: 20px 0;
      border-collapse: collapse;
      display: block;
      overflow-x: auto;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: #fcfbf8;
    }

    thead {
      background: #f1ede7;
    }

    th,
    td {
      padding: 12px 14px;
      border-bottom: 1px solid var(--border);
      text-align: left;
      vertical-align: top;
      white-space: pre-wrap;
    }

    th {
      font-weight: 700;
    }

    tr:last-child td {
      border-bottom: none;
    }

    code {
      font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, SFMono-Regular, Menlo, monospace;
      background: #f4f1ec;
      padding: 0.3em 0.45em;
      border-radius: 6px;
      border: 1px solid #e6ddd2;
      font-size: 0.92em;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    pre {
      display: block;
      max-width: 100%;
      // min-width: 0;
      background: #15181a;
      color: #f5f5f5;
      padding: 16px;
      margin: 20px 0;
      white-space: pre-wrap;
      overflow-x: auto;
      overflow-wrap: anywhere;
      word-break: break-word;
      border-radius: 12px;
      border: 1px solid #24292e;
      line-height: 1.7;

      code {
        background: transparent;
        padding: 0;
        color: inherit;
        white-space: inherit;
      }
    }

    hr {
      margin: 32px 0;
      border: 0;
      border-top: 1px solid var(--border);
    }

    br {
      line-height: 1.1;
    }
  }

  .section {
     margin: 1rem 0 12px;
  }

    .doc-title {
      font-size: 27px;
      margin: 1rem 0 12px;
    }
    .date {
      margin-bottom: 1rem;
      color: grey;
    }

  .doc-summary {
    display: flex;
    margin-top: 0.5rem;
    border-radius: 4px 8px 8px 12px;
    img {
      max-width: 430px;
      min-width: 300px;
      border-radius: 2px 0 0 10px;
    }
  

    p {
      font-size: 1.1rem;
      margin: 0;
      line-height: 1.7;
      color: var(--ink);
      background: #e6eff0;
    border-radius: 0 14px 14px 0;
    padding: 0.5rem;
    white-space: normal;
    }
  }

  @media (max-width: 980px) {
    .page {
      grid-template-columns: 1fr;
      max-width: 100%;
      width: 100%;
    }

    .sidebar,
    .toc {
      display: none;
    }

    article {
      padding: 20px 20px 40px;
    }
  }
</style>
