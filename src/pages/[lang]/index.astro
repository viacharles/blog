---
const fallbackPath = encodeURI('/zh-Hant/AngularMaterial屬性的預設errors');
const landingByLang: Record<string, string> = {
  en: fallbackPath,
  'zh-Hant': fallbackPath,
  ja: fallbackPath
};

export async function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh-Hant' } },
    { params: { lang: 'ja' } }
  ];
}

const { lang } = Astro.params;
return Astro.redirect(landingByLang[lang ?? ''] ?? fallbackPath);
---
