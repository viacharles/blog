---
const { lang = 'en', slug = '' } = Astro.props;
const languages = [
  { code: 'en', label: 'English' },
  { code: 'zh-Hant', label: '中文 (ZH)' },
  { code: 'ja', label: '日本語' }
];
const slugPath = slug ? `/${slug}` : '';
---

<header class="site-header">
  <div class="header-left">
    <button class="icon-button menu-button" data-menu-open aria-label="Open menu">
      <span class="menu-icon"></span>
    </button>
    <div class="title">viacharles 的技術倉</div>
  </div>

  <div class="header-right">
    <a class="icon-link" href="https://github.com/viacharles" target="_blank" rel="noreferrer" aria-label="GitHub">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path
          d="M12 2c-5.52 0-10 4.58-10 10.23 0 4.51 2.87 8.34 6.84 9.7.5.1.68-.22.68-.49 0-.24-.01-1.04-.02-1.88-2.78.62-3.37-1.21-3.37-1.21-.46-1.19-1.12-1.51-1.12-1.51-.92-.65.07-.64.07-.64 1.02.07 1.56 1.07 1.56 1.07.9 1.6 2.36 1.14 2.94.87.09-.66.35-1.14.63-1.4-2.22-.26-4.56-1.13-4.56-5.04 0-1.11.39-2.01 1.03-2.72-.1-.26-.45-1.3.1-2.71 0 0 .85-.28 2.79 1.04a9.47 9.47 0 0 1 5.08 0c1.94-1.32 2.79-1.04 2.79-1.04.55 1.41.2 2.45.1 2.71.64.71 1.03 1.61 1.03 2.72 0 3.92-2.35 4.78-4.59 5.03.36.32.68.95.68 1.91 0 1.38-.02 2.49-.02 2.83 0 .27.18.59.69.49 3.96-1.36 6.82-5.2 6.82-9.7C22 6.58 17.52 2 12 2z"
        />
      </svg>
    </a>

    <label class="lang-select">
      <span class="sr-only">Language</span>
      <select
        name="lang"
        aria-label="Language"
        data-slug={slug}
        onchange={`const lang = this.value; const slug = this.dataset.slug; location.href = '/' + lang + (slug ? '/' + slug : '');`}
      >
        {languages.map((item) => (
          <option value={item.code} selected={item.code === lang}>
            {item.label}
          </option>
        ))}
      </select>
    </label>
  </div>
</header>

<style lang="scss">
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px;
    height: var(--header-height);
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);

    .header-left {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .title {
      font-weight: 600;
      font-size: 18px;
    }

    .header-right {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .icon-link {
      width: 36px;
      height: 36px;
      display: grid;
      place-items: center;
      border-radius: 10px;
      background: var(--surface);

      svg {
        width: 34px;
        height: 34px;
        fill: #4ea4ef;
      }
    }

    .lang-select {
      position: relative;

      select {
        appearance: none;
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 8px 36px 8px 12px;
        background: var(--surface);
        font-size: 1rem;
        font-weight: 500;
        cursor: pointer;
      }

      &::after {
        content: '▾';
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--muted);
        pointer-events: none;
      }
    }

    .menu-button {
      display: none;
    }

    .menu-icon {
      width: 22px;
      height: 2px;
      background: var(--ink);
      position: relative;
      display: block;

      &::before,
      &::after {
        content: '';
        position: absolute;
        left: 0;
        width: 22px;
        height: 2px;
        background: var(--ink);
      }

      &::before {
        top: -7px;
      }

      &::after {
        top: 7px;
      }
    }

    .icon-button {
      border: none;
      background: transparent;
      padding: 6px;
      cursor: pointer;
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  @media (max-width: 980px) {
    .site-header .menu-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
  }
</style>
