---
import avatarImage from '../assets/avata.png';

const { sections = [], lang = 'en', currentSlug = '' } = Astro.props;
const profileImageUrl = '/avata.png';
---

<nav class="sidebar-nav" aria-label="Documentation">
  <div class="profile-card">
    {profileImageUrl ? (
      <img class="profile-avatar" src={profileImageUrl} alt="charles avatar" />
    ) : (
      <div class="profile-avatar profile-avatar-placeholder" aria-hidden="true">V</div>
    )}
    <p class="profile-name">charles</p>
  </div>

  {sections.map((section) => (
    <details class="menu-group" open={section.items.some((item) => item.slug === currentSlug)}>
      <summary>{section.title} ({section.items.length})</summary>
      <ul>
        {section.items.map((item) => (
          <li class={item.slug === currentSlug ? 'active' : ''}>
            <a href={`/${lang}/${item.slug}`}>{item.slug === currentSlug ? '>' : ''} {item.title}</a>
          </li>
        ))}
      </ul>
    </details>
  ))}
</nav>

<style lang="scss">
  .sidebar-nav {
    display: flex;
    flex-direction: column;
    font-size: 14px;

    .profile-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      gap: 10px;
      padding: 18px 12px 14px;
      margin-bottom: 8px;
    }

    .profile-avatar {
      width: 85px;
      height: 85px;
      // border-radius: 999px;
      object-fit: cover;
      border: 2px solid #dceaf0;
      background: linear-gradient(135deg, #f7fbfc, #e6f2f5);
      box-shadow: 0 10px 24px rgba(13, 156, 198, 0.08);
    }

    .profile-avatar-placeholder {
      display: grid;
      place-items: center;
      color: var(--accent-2);
      font-size: 2rem;
      font-weight: 700;
    }

    .profile-name {
      margin: 0;
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: 0.02em;
    }

    .menu-group {
      padding: 12px 0 6px 12px;

      summary {
        cursor: pointer;
        font-size: 1rem;
        font-weight: 600;
        color: var(--muted);
        list-style: none;

        &::-webkit-details-marker {
          display: none;
        }
      }

      ul {
        list-style: none;
        padding: 8px 0 0 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }

      li {
        a {
          display: block;
          border-radius: 8px;
          font-size: 1rem;
          text-decoration: none;
          color: var(--ink);
        }

        &.active a {
          color: var(--accent-2);
        }
      }
    }
  }
</style>
